# NetworKIN environment variables
# Copy this file to .env and fill in your values.
# Do NOT commit .env to version control.

# --- Database (required) ---
# SQLite example (development):
NETWORKIN_DATABASE_URL=sqlite:///./dev.db
# PostgreSQL example (production):
# NETWORKIN_DATABASE_URL=postgresql://user:password@localhost:5432/networkin

# --- Data paths (optional — defaults used if unset) ---
# Path to STRING v12.0 flat-file network (gzip TSV).
# Defaults to data/string_data/9606.links.v12.0.tsv.gz
# NETWORKIN_STRING_FLAT_FILE=data/string_data/9606.links.v12.0.tsv.gz

# Path to local PhosphoSitePlus export (TSV).
# Download manually from https://www.phosphosite.org/downloads/
# and place the file here; only required if OmniPath is unavailable.
# NETWORKIN_PSP_LOCAL_FILE=data/Phosphorylation_site_dataset.tsv

# --- Scoring thresholds (optional) ---
# STRING combined-score threshold [0, 1000].  Default: 400
# NETWORKIN_STRING_MIN_SCORE=400

# --- Cache (optional) ---
# Directory for Parquet cache files.  Default: .cache
# NETWORKIN_CACHE_DIR=.cache

# --- Numba / JIT (optional) ---
# Set to 1 to disable Numba JIT on first run (avoids compilation delay).
# NUMBA_DISABLE_JIT=0
